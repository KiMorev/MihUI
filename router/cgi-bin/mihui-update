#!/bin/sh
set -eu

APP_DIR="${MIHUI_DIR:-/opt/etc/mihui}"
WWW_DIR="$APP_DIR/www"
ENV_FILE="$APP_DIR/mihui.env"
INIT_SCRIPT="${MIHUI_INIT_SCRIPT:-/opt/etc/init.d/S99mihui}"
DEFAULT_RELEASE_URL="https://github.com/KiMorev/MihUI/releases/latest/download/mihui-router.tar.gz"
SOURCE_ARCHIVE_URL="${MIHUI_SOURCE_ARCHIVE_URL:-https://github.com/KiMorev/MihUI/archive/refs/heads/main.tar.gz}"
RELEASE_URL="${MIHUI_RELEASE_URL:-$DEFAULT_RELEASE_URL}"
DOWNLOAD_URLS="${MIHUI_DOWNLOAD_URLS:-}"
TMP_DIR=""
PACKAGE_DIR=""
DOWNLOADED_ARCHIVE=""
LOCK_DIR="${TMPDIR:-/tmp}/mihui-update.lock"

[ -f /opt/etc/profile ] && . /opt/etc/profile
[ -f "$ENV_FILE" ] && . "$ENV_FILE"
[ -n "${MIHUI_RELEASE_URL:-}" ] && RELEASE_URL="$MIHUI_RELEASE_URL"
[ -n "${MIHUI_DOWNLOAD_URLS:-}" ] && DOWNLOAD_URLS="$MIHUI_DOWNLOAD_URLS"

respond_json() {
  status="$1"
  body="$2"
  printf 'Status: %s\r\n' "$status"
  printf 'Content-Type: application/json\r\n'
  printf 'Cache-Control: no-store\r\n'
  printf '\r\n'
  printf '%s\n' "$body"
  exit 0
}

fail() {
  respond_json "500 Internal Server Error" "{\"ok\":false,\"message\":\"$1\"}"
}

cleanup() {
  if [ -n "$TMP_DIR" ] && [ -d "$TMP_DIR" ]; then
    rm -rf "$TMP_DIR"
  fi
  if [ -d "$LOCK_DIR" ]; then
    rmdir "$LOCK_DIR" 2>/dev/null || true
  fi
}

trap cleanup EXIT

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

setup_download_urls() {
  if [ -n "$DOWNLOAD_URLS" ]; then
    return
  fi

  DOWNLOAD_URLS="$RELEASE_URL"
  if [ "$RELEASE_URL" = "$DEFAULT_RELEASE_URL" ]; then
    DOWNLOAD_URLS="$DOWNLOAD_URLS $SOURCE_ARCHIVE_URL"
  fi
}

make_tmp_dir() {
  mktemp -d "${TMPDIR:-/tmp}/mihui-update.XXXXXX" 2>/dev/null || {
    local_dir="${TMPDIR:-/tmp}/mihui-update.$$"
    rm -rf "$local_dir"
    mkdir -p "$local_dir"
    printf '%s\n' "$local_dir"
  }
}

download_file() {
  url="$1"
  target="$2"

  if command_exists curl; then
    curl -fL --connect-timeout 20 -o "$target" "$url" >/dev/null 2>&1 && return 0
  fi

  if command_exists wget; then
    wget -O "$target" "$url" >/dev/null 2>&1 && return 0
  fi

  return 1
}

download_package_archive() {
  setup_download_urls

  for url in $DOWNLOAD_URLS; do
    archive_name="${url##*/}"
    case "$archive_name" in
      *.tar.gz|*.tgz|*.tar|*.zip) ;;
      *) archive_name="mihui-router.tar.gz" ;;
    esac

    DOWNLOADED_ARCHIVE="$TMP_DIR/$archive_name"
    rm -f "$DOWNLOADED_ARCHIVE"
    if download_file "$url" "$DOWNLOADED_ARCHIVE"; then
      return 0
    fi
  done

  return 1
}

extract_archive() {
  archive="$1"
  target="$2"
  mkdir -p "$target"

  case "$archive" in
    *.tar.gz|*.tgz)
      tar -xzf "$archive" -C "$target" >/dev/null 2>&1
      return
      ;;
    *.tar)
      tar -xf "$archive" -C "$target" >/dev/null 2>&1
      return
      ;;
    *.zip)
      if command_exists unzip; then
        unzip -q "$archive" -d "$target" >/dev/null 2>&1
        return
      fi

      if command_exists busybox; then
        busybox unzip -q "$archive" -d "$target" >/dev/null 2>&1
        return
      fi
      ;;
  esac

  return 1
}

package_from_source_tree() {
  source_dir="$1"
  target_dir="$2"

  [ -f "$source_dir/index.html" ] || return 1
  [ -f "$source_dir/styles.css" ] || return 1
  [ -f "$source_dir/app.js" ] || return 1
  [ -f "$source_dir/mihomo-editor.html" ] || return 1
  [ -f "$source_dir/router/cgi-bin/mihui-update" ] || return 1
  [ -f "$source_dir/router/mihui_server.py" ] || return 1

  mkdir -p "$target_dir/www" "$target_dir/cgi-bin"
  cp "$source_dir/index.html" "$source_dir/styles.css" "$source_dir/app.js" "$source_dir/mihomo-editor.html" "$target_dir/www/"
  cp "$source_dir/router/cgi-bin/mihui-update" "$target_dir/cgi-bin/"
  cp "$source_dir/router/mihui_server.py" "$target_dir/"
  [ -f "$source_dir/router/uninstall.sh" ] && cp "$source_dir/router/uninstall.sh" "$target_dir/"
  [ -f "$source_dir/VERSION" ] && cp "$source_dir/VERSION" "$target_dir/"
  return 0
}

select_package_dir() {
  root="$1"

  if [ -f "$root/www/index.html" ] && [ -f "$root/cgi-bin/mihui-update" ]; then
    printf '%s\n' "$root"
    return 0
  fi

  if package_from_source_tree "$root" "$TMP_DIR/source-package"; then
    printf '%s\n' "$TMP_DIR/source-package"
    return 0
  fi

  for candidate in "$root"/*; do
    [ -d "$candidate" ] || continue

    if [ -f "$candidate/www/index.html" ] && [ -f "$candidate/cgi-bin/mihui-update" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi

    if package_from_source_tree "$candidate" "$TMP_DIR/source-package"; then
      printf '%s\n' "$TMP_DIR/source-package"
      return 0
    fi
  done

  return 1
}

if [ "${REQUEST_METHOD:-POST}" != "POST" ]; then
  respond_json "405 Method Not Allowed" '{"ok":false,"message":"POST required"}'
fi

if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  respond_json "409 Conflict" '{"ok":false,"message":"update already running"}'
fi

TMP_DIR=$(make_tmp_dir)
download_package_archive || fail "download failed"
extract_archive "$DOWNLOADED_ARCHIVE" "$TMP_DIR/package" || fail "extract failed"
PACKAGE_DIR=$(select_package_dir "$TMP_DIR/package") || fail "downloaded package has unsupported layout"

[ -f "$PACKAGE_DIR/www/index.html" ] || fail "package does not contain www/index.html"
[ -f "$PACKAGE_DIR/cgi-bin/mihui-update" ] || fail "package does not contain cgi-bin/mihui-update"
[ -f "$PACKAGE_DIR/mihui_server.py" ] || fail "package does not contain mihui_server.py"

NEW_WWW="$APP_DIR/www.new.$$"
OLD_WWW="$APP_DIR/www.old.$$"

rm -rf "$NEW_WWW" "$OLD_WWW"
mkdir -p "$NEW_WWW/cgi-bin"
cp -R "$PACKAGE_DIR/www/." "$NEW_WWW/" || fail "copy www failed"
cp -R "$PACKAGE_DIR/cgi-bin/." "$NEW_WWW/cgi-bin/" || fail "copy cgi failed"
chmod +x "$NEW_WWW/cgi-bin/mihui-update"

if [ -f "$PACKAGE_DIR/uninstall.sh" ]; then
  cp "$PACKAGE_DIR/uninstall.sh" "$APP_DIR/uninstall.sh" || fail "copy uninstall failed"
  chmod +x "$APP_DIR/uninstall.sh"
fi

cp "$PACKAGE_DIR/mihui_server.py" "$APP_DIR/mihui_server.py" || fail "copy server failed"
[ -f "$PACKAGE_DIR/VERSION" ] && cp "$PACKAGE_DIR/VERSION" "$APP_DIR/VERSION"

[ -d "$WWW_DIR" ] && mv "$WWW_DIR" "$OLD_WWW"
mv "$NEW_WWW" "$WWW_DIR" || fail "replace www failed"
rm -rf "$OLD_WWW"

if [ -x "$INIT_SCRIPT" ]; then
  ( sleep 2; "$INIT_SCRIPT" restart >/dev/null 2>&1 ) &
fi

respond_json "200 OK" '{"ok":true,"message":"MihUI updated"}'
